# Polkit
# Polkit позволяет управлять привилегиями для не-root пользователей.

# Проверим, что Polkit установлен:
dpkg -l | grep polkit
# Заходим в системные файлы Polkit:
cd /usr/share/polkit-1/actions/
ls *.policy # просмотр доступных политик
# Просмотрим политику для systemd:
cat org.freedesktop.systemd1.policy
# В этом файле определены действия, которые могут быть выполнены через Polkit для systemd, такие как управление юнитами, изменение настроек и т.д.
# Основные значения для правил Polkit:
# no — запрещено
# yes — разрешено без аутентификации
# auth_self — требуется пароль текущего пользователя
# auth_admin — требуется пароль администратора (root / sudo)
# *_keep — с кэшированием учётных данных на короткое время (~5 минут)

# Включим логирование для Polkit:
sudo tee /etc/polkit-1/rules.d/00-access.rules <<EOF
polkit.addRule(function(action, subject){
    polkit.log("action="+action);
    polkit.log("subject="+subject);
});
EOF
# синтаксис создания правил Polkit использует JavaScript-подобный язык. 

# Создадим правило для управления systemd:
sudo tee /etc/polkit-1/rules.d/49-erick-systemd.rules > /dev/null <<'EOF'
polkit.addRule(function(action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        subject.user == "erick") {
        return polkit.Result.YES;
    }
});
EOF # разрешаем пользователю выполнять действия управления systemd

# Проверим действия, доступные через Polkit:
pkaction # список всех действий
# 
# Проверим авторизацию для конкретного действия:
pkcheck --action-id org.freedesktop.systemd1.manage-units --process $$ # проверка прав для управления systemd
# pkcheck: проверяет, имеет ли текущий пользователь права на выполнение указанного действия.
# Перезагрузим службу Polkit, чтобы применить изменения:
sudo systemctl restart polkit
# Теперь пользователь должен иметь возможность управлять systemd без необходимости использовать sudo.
# Проверим это, попытавшись перезапустить службу (например, cron):
systemctl --user restart cron.service
# Удалим созданные правила после проверки:
sudo rm /etc/polkit-1/rules.d/00-access.rules
sudo rm /etc/polkit-1/rules.d/01-systemd.rules
sudo systemctl restart polkit

# PAM
# PAM (Pluggable Authentication Modules) — это система, которая позволяет администраторам настраивать методы аутентификации для различных сервисов в Linux.
#PAM предоставляет гибкую аутентификацию через модули.
# Тест аутентификации пользователя otus0512 для сервиса login
pamtester login otus0512 authenticate

# Тест полного цикла (auth + account + session)
pamtester -v login otus0512 authenticate open_session close_session

# Посмотрим конфигурацию PAM для SSH:
cat /etc/pam.d/sshd
# В этом файле определены модули PAM, используемые при аутентификации через SSH, а именно:
@include common-auth # включает общие настройки аутентификации
account    required     pam_nologin.so # запрещает вход, если файл /etc/nologin существует
@include common-account # включает общие настройки учетных записей
session [success=ok ignore=ignore module_unknown=ignore default=bad]        pam_selinux.so close # управление контекстами SELinux
session    required     pam_loginuid.so # установка идентификатора входа
session    optional     pam_keyinit.so force revoke # инициализация ключей
@include common-session # включает общие настройки сессий
session    optional     pam_motd.so  motd=/run/motd.dynamic # отображение сообщения дня
session    optional     pam_motd.so noupdate # отображение статического сообщения дня
session    optional     pam_mail.so standard noenv # проверка почты
session    required     pam_limits.so # управление лимитами ресурсов
session    required     pam_env.so # [1] установка переменных окружения
session    required     pam_env.so user_readenv=1 envfile=/etc/default/locale # [2] установка переменных окружения из файла
session [success=ok ignore=ignore module_unknown=ignore default=bad]        pam_selinux.so open # управление контекстами SELinux
@include common-password # включает общие настройки паролей
# required - если модуль неудачен, вся аутентификация проваливается. Что это значит?
# Если модуль помечен как required и он не проходит, то вся аутентификация завершается неудачей, независимо от результатов других модулей.
# requisite - если модуль неудачен, аутентификация проваливается сразу. 
# Это означает, что если модуль помечен как requisite и он не проходит, то аутентификация завершается немедленно без проверки других модулей.
# sufficient - если модуль успешен и нет предыдущих неудач, аутентификация успешна.
# Если модуль помечен как sufficient и он проходит успешно, а все предыдущие модули также прошли успешно, то аутентификация завершается успешно без проверки дальнейших модулей.
# optional - результат модуля не влияет на общую аутентификацию.
# Модуль помеченный как optional не влияет на итоговый результат аутентификации, независимо от того, прошел он или нет.

